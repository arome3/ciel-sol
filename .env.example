# Ciel Environment Variables
# Copy to .env and fill in real values. See CLAUDE.md for descriptions.

# === Required ===

# Helius — primary RPC and LaserStream gRPC (see spec Section 3.5)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY_HERE

# Triton One — fallback RPC (see spec Section 3.5)
TRITON_API_KEY=YOUR_TRITON_API_KEY_HERE

# Groq — primary LLM inference (see spec Section 5.1)
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Fireworks — fallback LLM inference (see spec Section 5.4)
FIREWORKS_API_KEY=YOUR_FIREWORKS_API_KEY_HERE

# PostgreSQL — verdict log store (see spec Section 13.1)
DATABASE_URL=postgres://ciel:ciel_pass@localhost:5432/ciel

# Ed25519 signing key — path to JSON keypair file (see spec Section 7.3)
CIEL_SIGNING_KEY_PATH=./keys/ciel.json

# === Optional ===

# Helius LaserStream gRPC endpoint (see spec Section 3.4)
# HELIUS_LASERSTREAM_URL=https://laserstream.helius-rpc.com

# Jito Block Engine URL (see spec Section 8.3)
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# x402 treasury pubkey — receives USDC micropayments (see spec Section 11.1)
# CIEL_TREASURY_PUBKEY=YOUR_TREASURY_PUBKEY_HERE
